{
  "name": "product-pass",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3023",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "favicons": "node scripts/generate-favicons.mjs",
    "worker:dev": "wrangler dev --config workers/productpass-api/wrangler.jsonc --port 8787",
    "worker:deploy": "wrangler deploy --config workers/productpass-api/wrangler.jsonc",
    "db:migrate:local": "wrangler d1 migrations apply productpass-db --local --config workers/productpass-api/wrangler.jsonc",
    "db:migrate:remote": "wrangler d1 migrations apply productpass-db --remote --config workers/productpass-api/wrangler.jsonc",
    "db:seed:local": "curl -s -X POST http://localhost:8787/v1/admin/seed"
  },
  "dependencies": {
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260524.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.14.0"
  }
}
